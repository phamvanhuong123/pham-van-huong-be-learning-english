generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH & RBAC
// ─────────────────────────────────────────
model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  name                String?
  avatarUrl           String?
  targetScore         Int?
  examDate            DateTime?
  emailVerified       Boolean   @default(false)
  isBanned            Boolean   @default(false)
  isSuperAdmin        Boolean   @default(false)
  vipExpiresAt        DateTime?
  phoneNumber         String?   @unique
  phoneVerified       Boolean   @default(false)
  registrationIp      String?
  verificationToken   String?
  verificationExpiry  DateTime?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  userRoles UserRole[]
  sessions  UserSession[]

  @@index([email])
  @@index([verificationToken])
  @@index([resetPasswordToken])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String  @id @default(uuid())
  code        String  @unique
  description String?
  group       String?

  rolePermissions RolePermission[]
}

model UserRole {
  id        String    @id @default(uuid())
  userId    String
  roleId    String
  grantedBy String?
  grantedAt DateTime  @default(now())
  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  deviceInfo   String?
  ipAddress    String?
  loginAt      DateTime @default(now())
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  isActive     Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, lastActiveAt])
}


// ─────────────────────────────────────────
// Exam
// ─────────────────────────────────────────
model Exam {
  id           String      @id @default(uuid())
  title        String
  description  String?
  part         ExamPart
  difficulty   Difficulty
  type         ExamType    @default(FREE)
  duration     Int         
  isPublished  Boolean     @default(false)
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?
  parentExamId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  parentExam   Exam?  @relation("ExamParts", fields: [parentExamId], references: [id])
  childExams   Exam[] @relation("ExamParts")

  @@index([part, difficulty, type, isPublished, isDeleted])
  @@index([isDeleted, deletedAt])
}

enum ExamPart {
  PART1
  PART2
  PART3
  PART4
  PART5
  PART6
  PART7
  FULL
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ExamType {
  FREE
  VIP
}