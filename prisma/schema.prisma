generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH & RBAC
// ─────────────────────────────────────────
model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  name                String?
  avatarUrl           String?
  targetScore         Int?
  examDate            DateTime?
  emailVerified       Boolean   @default(false)
  isBanned            Boolean   @default(false)
  isSuperAdmin        Boolean   @default(false)
  vipExpiresAt        DateTime?
  phoneNumber         String?   @unique
  phoneVerified       Boolean   @default(false)
  registrationIp      String?
  verificationToken   String?
  verificationExpiry  DateTime?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  userRoles UserRole[]
  sessions  UserSession[]
  results   Result[]
  adminLogs AdminLog[]

  @@index([email])
  @@index([verificationToken])
  @@index([resetPasswordToken])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String  @id @default(uuid())
  code        String  @unique
  description String?
  group       String?

  rolePermissions RolePermission[]
}

model UserRole {
  id        String    @id @default(uuid())
  userId    String
  roleId    String
  grantedBy String?
  grantedAt DateTime  @default(now())
  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  deviceInfo   String?
  ipAddress    String?
  loginAt      DateTime @default(now())
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  isActive     Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, lastActiveAt])
}

// ─────────────────────────────────────────
// Exam
// ─────────────────────────────────────────
model Exam {
  id           String     @id @default(uuid())
  title        String
  description  String?
  part         ExamPart
  difficulty   Difficulty
  type         ExamType   @default(FREE)
  duration     Int
  isPublished  Boolean    @default(false)
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  parentExamId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  parentExam    Exam?          @relation("ExamParts", fields: [parentExamId], references: [id])
  childExams    Exam[]         @relation("ExamParts")
  passageGroups PassageGroup[]
  questions     Question[]
  results       Result[]

  @@index([part, difficulty, type, isPublished, isDeleted])
  @@index([isDeleted, deletedAt])
}

enum ExamPart {
  PART1
  PART2
  PART3
  PART4
  PART5
  PART6
  PART7
  FULL
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ExamType {
  FREE
  VIP
}

// ─────────────────────────────────────────
// GrammarTopic, PassageGroup, Passage, Question, Option
// ─────────────────────────────────────────

model GrammarTopic {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?

  questions Question[]
}

model PassageGroup {
  id     String      @id @default(uuid())
  examId String?
  type   PassageType @default(SINGLE)

  exam      Exam?      @relation(fields: [examId], references: [id], onDelete: SetNull)
  passages  Passage[]
  questions Question[]

  @@index([examId])
}

model Passage {
  id             String    @id @default(uuid())
  passageGroupId String
  content        String?
  transcript     String?   // Lời thoại (Part 3,4) hoặc Bản dịch (Part 6,7)
  order          Int
  mediaUrl       String?
  mediaType      MediaType @default(TEXT)

  passageGroup PassageGroup @relation(fields: [passageGroupId], references: [id], onDelete: Cascade)

  @@index([passageGroupId])
}

model Question {
  id             String     @id @default(uuid())
  examId         String?
  passageGroupId String?
  grammarTopicId String?
  order          Int        @default(0)
  questionText   String?
  difficulty     Difficulty @default(MEDIUM)
  explanation    String?
  metadata       Json?
  isDeleted      Boolean    @default(false)
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  exam         Exam?         @relation(fields: [examId], references: [id], onDelete: SetNull)
  passageGroup PassageGroup? @relation(fields: [passageGroupId], references: [id], onDelete: SetNull)
  grammarTopic GrammarTopic? @relation(fields: [grammarTopicId], references: [id], onDelete: SetNull)
  options      Option[]
  resultDetails ResultDetail[]

  @@index([examId, order])
  @@index([grammarTopicId])
  @@index([isDeleted])
}

model Option {
  id         String      @id @default(uuid())
  questionId String
  label      OptionLabel
  text       String
  isCorrect  Boolean     @default(false)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

enum PassageType {
  SINGLE
  DOUBLE
  TRIPLE
}

enum MediaType {
  TEXT
  AUDIO
  IMAGE
  VIDEO
}

enum OptionLabel {
  A
  B
  C
  D
}

// ─────────────────────────────────────────
// Result
// ─────────────────────────────────────────
model Result {
  id               String   @id @default(uuid())
  userId           String
  examId           String?
  grammarTopicId   String?
  status           String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, ABANDONED
  score            Int      @default(0)
  totalQ           Int      @default(0)
  correctQ         Int      @default(0)
  timeTaken        Int      @default(0)        // giây
  startedAt        DateTime?                   // validate server-side
  submittedAt      DateTime?
  listeningScore   Int?                        // 0-495
  readingScore     Int?                        // 0-495
  listeningCorrect Int?
  readingCorrect   Int?
  tabSwitchCount   Int      @default(0)        // anti-cheat
  isFullTest       Boolean  @default(false)
  partBreakdown    Json?    // { PART1: { total: 6, correct: 5 }, ... }
  weakPoints       Json?    // ["PART4", "PART7"]
  xpEarned         Int      @default(0)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam         Exam?         @relation(fields: [examId], references: [id], onDelete: SetNull)
  resultDetails ResultDetail[]

  @@index([userId, submittedAt])
  @@index([examId])
}

model ResultDetail {
  id               String  @id @default(uuid())
  resultId         String
  questionId       String
  selectedLabel    OptionLabel?
  isCorrect        Boolean @default(false)
  timeTakenSeconds Int?

  result   Result   @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([resultId, questionId])
  @@index([resultId])
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String   // "user.ban", "subscription.approve"...
  targetType String   // "User", "Subscription", "Exam"...
  targetId   String?
  detail     Json?    // snapshot trước/sau
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}